# VPS RDP Workstation - Git Ignore
# ================================

# Logs
logs/
*.log
/var/log/vps-setup/

# Ansible artifacts
*.retry

# Ansible Vault secrets (NEVER commit)
.vault_password
**/vault.yml
**/vault.yaml
*.vault.yml
logs/facts_cache/

# Environment files
.env
.env.local
*.env

# IDE settings
.idea/
.vscode/
*.sublime-*

# OS files
.DS_Store
Thumbs.db
*~

# Secrets (never commit these)
*.pem
*.key
*password*
*secret*
inventory/group_vars/vault.yml

# Temporary files
tmp/
*.tmp
*.temp
*.swp
*.swo

# Archives
*.tar.gz
*.zip

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/

# Node
node_modules/

# Build artifacts
dist/
build/
