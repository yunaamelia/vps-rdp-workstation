[manager]
show_hidden = true
sort_by = "natural"
sort_sensitive = false
sort_reverse = false
sort_dir_first = true
linemode = "size"
show_symlink = true

[preview]
tab_size = 2
max_width = 600
max_height = 900
cache_dir = ""

[opener]
edit = [
  { run = 'code "$@"', block = true, for = "unix" },
  { run = 'vim "$@"', block = true },
]
open = [
  { run = 'xdg-open "$@"', desc = "Open" },
]

[tasks]
micro_workers = 5
macro_workers = 10
bizarre_retry = 5

[plugin]
preload = []

[theme]
# Catppuccin Mocha colors
