// {{ ansible_managed }}
// Firefox Privacy & Performance Configuration for VPS RDP Workstation
// Generated: {{ ansible_date_time.iso8601 }}
// Reference: https://github.com/yokoffing/Betterfox

//=============================================================================
// PRIVACY SETTINGS
//=============================================================================

// Enhanced Tracking Protection - Strict Mode
user_pref("browser.contentblocking.category", "strict");
user_pref("privacy.trackingprotection.enabled", true);
user_pref("privacy.trackingprotection.socialtracking.enabled", true);
user_pref("privacy.annotate_channels.strict_list.enabled", true);

// Fingerprinting protection
user_pref("privacy.resistFingerprinting", false); // Can break sites, disabled
user_pref("privacy.fingerprintingProtection", true);

// Cookie behavior - Reject cross-site tracking cookies
user_pref("network.cookie.cookieBehavior", 5);

// Disable telemetry
user_pref("toolkit.telemetry.enabled", false);
user_pref("toolkit.telemetry.unified", false);
user_pref("toolkit.telemetry.archive.enabled", false);
user_pref("datareporting.healthreport.uploadEnabled", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);

// Disable studies
user_pref("app.shield.optoutstudies.enabled", false);
user_pref("app.normandy.enabled", false);

// Disable Pocket
user_pref("extensions.pocket.enabled", false);

// Disable Firefox accounts
user_pref("identity.fxaccounts.enabled", false);

//=============================================================================
// APPEARANCE
//=============================================================================

// Dark theme preference
user_pref("ui.systemUsesDarkTheme", 1);
user_pref("browser.in-content.dark-mode", true);
user_pref("devtools.theme", "dark");
user_pref("extensions.activeThemeID", "firefox-compact-dark@mozilla.org");

// Homepage - blank
user_pref("browser.startup.homepage", "about:blank");
user_pref("browser.startup.page", 1);
user_pref("browser.newtabpage.enabled", false);

//=============================================================================
// PERFORMANCE (RDP optimized)
//=============================================================================

// Hardware acceleration (may need to disable for RDP)
user_pref("layers.acceleration.disabled", false);
user_pref("gfx.webrender.all", true);

// Reduce animations for better RDP performance
user_pref("ui.prefersReducedMotion", 1);

// Memory optimization
user_pref("browser.sessionhistory.max_entries", 10);
user_pref("browser.cache.disk.capacity", 256000);

//=============================================================================
// SECURITY
//=============================================================================

// HTTPS-Only Mode
user_pref("dom.security.https_only_mode", true);
user_pref("dom.security.https_only_mode_ever_enabled", true);

// Safe browsing
user_pref("browser.safebrowsing.malware.enabled", true);
user_pref("browser.safebrowsing.phishing.enabled", true);

// Disable risky features
user_pref("dom.disable_beforeunload", true);
user_pref("dom.disable_window_move_resize", true);

//=============================================================================
// DEVELOPER TOOLS
//=============================================================================

// Enable developer tools
user_pref("devtools.toolbox.host", "right");
user_pref("devtools.inspector.showUserAgentStyles", true);
user_pref("devtools.netmonitor.persistlog", true);
