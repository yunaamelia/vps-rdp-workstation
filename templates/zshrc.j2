# {{ ansible_managed }}
# Zsh configuration for VPS Developer Workstation
# Generated: {{ ansible_date_time.iso8601 }}

#===============================================================================
# Oh My Zsh Configuration
#===============================================================================

# Path to Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme (we use Starship instead)
ZSH_THEME=""

# Case-sensitive completion
CASE_SENSITIVE="false"

# Auto-update behavior
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 7

# Uncomment to disable auto-setting terminal title
# DISABLE_AUTO_TITLE="true"

# Command auto-correction
ENABLE_CORRECTION="false"

# Waiting dots while completing
COMPLETION_WAITING_DOTS="true"

# Plugins
plugins=(
{% for plugin in zsh_builtin_plugins %}
  {{ plugin }}
{% endfor %}
{% for plugin in zsh_custom_plugins %}
  {{ plugin.name }}
{% endfor %}
)

source $ZSH/oh-my-zsh.sh

#===============================================================================
# Environment
#===============================================================================

# Language
export LANG="{{ vps_locale }}"
export LC_ALL="{{ vps_locale }}"

# Editor
export EDITOR="code --wait"
export VISUAL="code --wait"

# Paths
export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:$PATH"

# Node.js
export PATH="$HOME/.npm-global/bin:$PATH"

# Go (if installed)
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:$PATH"

# Rust (if installed)
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# History
export HISTSIZE=10000
export SAVEHIST=10000
export HISTFILE="$HOME/.zsh_history"
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

#===============================================================================
# Starship Prompt
#===============================================================================

eval "$(starship init zsh)"

#===============================================================================
# Aliases
#===============================================================================

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# Listing
alias ls='ls --color=auto'
alias ll='ls -alFh'
alias la='ls -A'
alias l='ls -CF'

# Safety
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Colorize
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias diff='diff --color=auto'

# System
alias update='sudo apt update && sudo apt upgrade -y'
alias install='sudo apt install'
alias remove='sudo apt remove'
alias search='apt search'

# Quick edit
alias zshrc='$EDITOR ~/.zshrc'
alias reload='source ~/.zshrc'

#===============================================================================
# Functions
#===============================================================================

# Create directory and cd into it
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# Extract various archive types
extract() {
  if [ -f "$1" ]; then
    case "$1" in
      *.tar.bz2) tar xjf "$1" ;;
      *.tar.gz)  tar xzf "$1" ;;
      *.bz2)     bunzip2 "$1" ;;
      *.rar)     unrar x "$1" ;;
      *.gz)      gunzip "$1" ;;
      *.tar)     tar xf "$1" ;;
      *.tbz2)    tar xjf "$1" ;;
      *.tgz)     tar xzf "$1" ;;
      *.zip)     unzip "$1" ;;
      *.Z)       uncompress "$1" ;;
      *.7z)      7z x "$1" ;;
      *)         echo "'$1' cannot be extracted" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# Quick HTTP server
serve() {
  local port="${1:-8000}"
  python3 -m http.server "$port"
}

#===============================================================================
# Welcome Message
#===============================================================================

if [[ -o interactive ]]; then
  echo ""
  echo "🚀 VPS Developer Workstation Ready"
  echo ""
fi
